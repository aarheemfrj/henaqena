generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  PENDING
  ACTIVE
  EXPIRED
  ARCHIVED
  REJECTED
}

enum UserLevel {
  QENAWY
  QENAWY_RAYEQ
  QENAWY_ASIL
}

model User {
  id              String         @id @default(cuid())
  name            String
  phone           String?        @unique
  email           String?        @unique
  avatarUrl       String?
  isProfilePrivate Boolean        @default(false)
  points          Int            @default(0)
  level           UserLevel      @default(QENAWY)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  passwordHash    String?
  phoneVerifiedAt DateTime?
  emailVerifiedAt DateTime?
  authProvider    String?
  preferredAreaIds String[] @default([])
  interests       String[] @default([])
  notificationScope String @default("all")
  notificationDigest Boolean @default(false)
  role            String   @default("USER")
  providers       Provider[]
  listings        Listing[]
  reviews         Review[]
  replies         ReviewReply[]
  notifications   Notification[]
  sessions        Session[]
  verificationCodes VerificationCode[]
  auditLogs       AuditLog[]
  providerReports ProviderReport[] @relation("reportedBy")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model VerificationCode {
  id         String   @id @default(cuid())
  userId     String
  channel    String
  target     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, channel])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  @@index([entity, entityId])
  @@index([createdAt])
}

model Area {
  id        String     @id @default(cuid())
  name      String
  city      String     @default("قنا")
  isActive  Boolean    @default(true)
  providers Provider[]
  listings  Listing[]
  ads       Ad[]
  priceGuides PriceGuide[]
  nowUpdates NowUpdate[]
  createdAt DateTime   @default(now())
}

model Provider {
  id          String          @id @default(cuid())
  name        String
  description String?
  phone       String?
  whatsapp    String?
  address     String?
  latitude    Float?
  longitude   Float?
  serviceMode String         @default("LOCAL")
  phoneType   String         @default("BUSINESS")
  openingTime String?
  closingTime String?
  communityAdded Boolean      @default(true)
  submissionKind String        @default("COMMUNITY")
  isVerified  Boolean         @default(false)
  status      ReviewStatus    @default(PENDING)
  ownerId     String?
  areaId      String
  owner       User?           @relation(fields: [ownerId], references: [id])
  area        Area            @relation(fields: [areaId], references: [id])
  images      ProviderImage[]
  reviews     Review[]
  categories  ProviderCategory[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  reports     ProviderReport[] @relation("providerReports")
}

model ProviderReport {
  id        String   @id @default(cuid())
  providerId String?
  reporterId String?
  kind      String
  name      String
  phone     String?
  note      String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime @default(now())
  provider  Provider? @relation("providerReports", fields: [providerId], references: [id], onDelete: SetNull)
  reporter  User?     @relation("reportedBy", fields: [reporterId], references: [id], onDelete: SetNull)
  @@index([status, createdAt])
}

model ProviderImage {
  id         String   @id @default(cuid())
  providerId String
  url        String
  sortOrder  Int      @default(0)
  kind       String   @default("work")
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model Category {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  isActive  Boolean           @default(true)
  providers ProviderCategory[]
}

model ProviderCategory {
  providerId String
  categoryId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([providerId, categoryId])
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String?
  price       Decimal       @db.Decimal(12, 2)
  status      ListingStatus @default(PENDING)
  ownerId     String
  areaId      String
  owner       User          @relation(fields: [ownerId], references: [id])
  area        Area          @relation(fields: [areaId], references: [id])
  images      ListingImage[]
  createdAt   DateTime      @default(now())
  expiresAt   DateTime?
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  sortOrder Int     @default(0)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Review {
  id           String       @id @default(cuid())
  providerId   String
  authorId     String
  quality      Int
  commitment   Int
  value        Int
  comment      String?
  status       ReviewStatus @default(PENDING)
  moderatedAt  DateTime?
  provider     Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])
  replies      ReviewReply[]
  createdAt    DateTime     @default(now())
  @@index([moderatedAt])
}

model ReviewReply {
  id          String    @id @default(cuid())
  reviewId    String
  authorId    String
  text        String
  moderatedAt DateTime?
  review      Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  @@index([moderatedAt])
}

model Ad {
  id          String       @id @default(cuid())
  name        String
  imageUrl    String
  description String?
  targetUrl   String?
  status      ReviewStatus @default(PENDING)
  weight      Int          @default(100)
  areaId      String?
  startsAt    DateTime
  endsAt      DateTime
  area        Area?        @relation(fields: [areaId], references: [id])
  createdAt   DateTime     @default(now())
}

model PriceGuide {
  id          String       @id @default(cuid())
  name        String
  category    String?
  minPrice    Decimal      @db.Decimal(12, 2)
  maxPrice    Decimal      @db.Decimal(12, 2)
  unit        String?
  sourceNote  String?
  status      ReviewStatus @default(PENDING)
  areaId      String?
  area        Area?        @relation(fields: [areaId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([status, updatedAt])
}

model NowUpdate {
  id          String       @id @default(cuid())
  title       String
  body        String?
  category    String       @default("عام")
  status      ReviewStatus @default(PENDING)
  areaId      String?
  startsAt    DateTime     @default(now())
  endsAt      DateTime?
  area        Area?        @relation(fields: [areaId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([status, startsAt, endsAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
