generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  PENDING
  ACTIVE
  EXPIRED
  ARCHIVED
  REJECTED
}

enum UserLevel {
  QENAWY
  QENAWY_RAYEQ
  QENAWY_ASIL
}

enum AdminRole {
  OWNER
  REVIEWER
  CONTENT_EDITOR
  MODERATOR
}

model User {
  id                   String             @id @default(cuid())
  name                 String
  phone                String?            @unique
  email                String?            @unique
  avatarUrl            String?
  isProfilePrivate     Boolean            @default(false)
  points               Int                @default(0)
  level                UserLevel          @default(QENAWY)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  passwordHash         String?
  phoneVerifiedAt      DateTime?
  emailVerifiedAt      DateTime?
  authProvider         String?
  authSubject          String?
  preferredAreaIds     String[]           @default([])
  interests            String[]           @default([])
  ageRange             String?
  gender               String?
  notificationScope    String             @default("all")
  notificationsEnabled Boolean            @default(true)
  notificationDigest   Boolean            @default(false)
  role                 String             @default("USER")
  providers            Provider[]
  listings             Listing[]
  reviews              Review[]
  replies              ReviewReply[]
  notifications        Notification[]
  sessions             Session[]
  verificationCodes    VerificationCode[]
  auditLogs            AuditLog[]
  providerReports      ProviderReport[]   @relation("reportedBy")
  providerFavorites    ProviderFavorite[]
  listingFavorites     ListingFavorite[]
  listingInterests     ListingInterest[]
  helpfulReviews       ReviewHelpful[]
  listingReports       ListingReport[]
  nowHelpfulVotes      NowHelpful[]
  supportTickets       SupportTicket[]
  adReactions          AdReaction[]
  favoriteLists        FavoriteList[]
  savedSearches        SavedSearch[]

  @@unique([authProvider, authSubject])
}

model AdminAccount {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         AdminRole      @default(REVIEWER)
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id        String       @id @default(cuid())
  tokenHash String       @unique
  adminId   String
  expiresAt DateTime
  createdAt DateTime     @default(now())
  admin     AdminAccount @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationCode {
  id         String    @id @default(cuid())
  userId     String
  channel    String
  target     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}

model Area {
  id          String       @id @default(cuid())
  name        String
  city        String       @default("قنا")
  isActive    Boolean      @default(true)
  providers   Provider[]
  listings    Listing[]
  ads         Ad[]
  priceGuides PriceGuide[]
  nowUpdates  NowUpdate[]
  createdAt   DateTime     @default(now())
}

model Provider {
  id             String             @id @default(cuid())
  name           String
  description    String?
  phone          String?
  whatsapp       String?
  socialPlatform String?
  socialUrl      String?
  address        String?
  latitude       Float?
  longitude      Float?
  serviceMode    String             @default("LOCAL")
  phoneType      String             @default("BUSINESS")
  openingTime    String?
  closingTime    String?
  communityAdded Boolean            @default(true)
  submissionKind String             @default("COMMUNITY")
  isVerified     Boolean            @default(false)
  status         ReviewStatus       @default(PENDING)
  kidFriendly    Boolean            @default(false)
  accessible     Boolean            @default(false)
  hasParking     Boolean            @default(false)
  acceptsCards   Boolean            @default(false)
  homeService    Boolean            @default(false)
  needsBooking   Boolean            @default(false)
  open24h        Boolean            @default(false)
  hasDelivery    Boolean            @default(false)
  ownerId        String?
  areaId         String
  owner          User?              @relation(fields: [ownerId], references: [id])
  area           Area               @relation(fields: [areaId], references: [id])
  images         ProviderImage[]
  reviews        Review[]
  categories     ProviderCategory[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  reports        ProviderReport[]   @relation("providerReports")
  services       ProviderService[]
  offers         ProviderOffer[]
  favorites      ProviderFavorite[]
}

model ProviderReport {
  id         String       @id @default(cuid())
  providerId String?
  reporterId String?
  kind       String
  name       String
  phone      String?
  note       String?
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  provider   Provider?    @relation("providerReports", fields: [providerId], references: [id], onDelete: SetNull)
  reporter   User?        @relation("reportedBy", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model ProviderImage {
  id         String   @id @default(cuid())
  providerId String
  url        String
  sortOrder  Int      @default(0)
  kind       String   @default("work")
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model ProviderFavorite {
  id         String        @id @default(cuid())
  userId     String
  providerId String
  listId     String?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  list       FavoriteList? @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId, listId])
  @@index([providerId])
  @@index([listId])
}

model FavoriteList {
  id        String             @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites ProviderFavorite[]

  @@index([userId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  label     String
  query     String?
  areaId    String?
  category  String?
  sort      String   @default("name")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProviderService {
  id          String       @id @default(cuid())
  providerId  String
  name        String
  description String?
  price       Decimal?     @db.Decimal(12, 2)
  priceNote   String?
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, status])
}

model ProviderOffer {
  id          String       @id @default(cuid())
  providerId  String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, status, endsAt])
}

model Category {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  isActive  Boolean            @default(true)
  providers ProviderCategory[]
}

model ProviderCategory {
  providerId String
  categoryId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([providerId, categoryId])
}

model Listing {
  id          String            @id @default(cuid())
  title       String
  description String?
  category    String            @default("للبيع")
  price       Decimal           @db.Decimal(12, 2)
  status      ListingStatus     @default(PENDING)
  ownerId     String
  areaId      String
  owner       User              @relation(fields: [ownerId], references: [id])
  area        Area              @relation(fields: [areaId], references: [id])
  images      ListingImage[]
  favorites   ListingFavorite[]
  interests   ListingInterest[]
  reports     ListingReport[]
  createdAt   DateTime          @default(now())
  expiresAt   DateTime?
}

model ListingFavorite {
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([listingId])
}

model ListingInterest {
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([listingId])
}

model ListingReport {
  id        String       @id @default(cuid())
  userId    String
  listingId String
  reason    String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
  @@index([userId, createdAt])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  sortOrder Int     @default(0)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Review {
  id            String          @id @default(cuid())
  providerId    String
  authorId      String
  quality       Int
  commitment    Int
  value         Int
  comment       String?
  status        ReviewStatus    @default(PENDING)
  pointsAwarded Boolean         @default(false)
  moderatedAt   DateTime?
  provider      Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  author        User            @relation(fields: [authorId], references: [id])
  replies       ReviewReply[]
  helpfulVotes  ReviewHelpful[]
  createdAt     DateTime        @default(now())

  @@index([moderatedAt])
}

model ReviewHelpful {
  userId    String
  reviewId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@index([reviewId])
}

model ReviewReply {
  id          String       @id @default(cuid())
  reviewId    String
  authorId    String
  text        String
  status      ReviewStatus @default(PENDING)
  moderatedAt DateTime?
  review      Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])
  createdAt   DateTime     @default(now())

  @@index([status, moderatedAt])
}

model Ad {
  id          String       @id @default(cuid())
  name        String
  imageUrl    String
  description String?
  targetUrl   String?
  status      ReviewStatus @default(PENDING)
  weight      Int          @default(100)
  areaId      String?
  startsAt    DateTime
  endsAt      DateTime
  area        Area?        @relation(fields: [areaId], references: [id])
  reactions   AdReaction[]
  createdAt   DateTime     @default(now())
}

model AdReaction {
  userId    String
  adId      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@id([userId, adId])
  @@index([adId])
}

model PriceGuide {
  id         String       @id @default(cuid())
  name       String
  category   String?
  minPrice   Decimal      @db.Decimal(12, 2)
  maxPrice   Decimal      @db.Decimal(12, 2)
  unit       String?
  sourceNote String?
  status     ReviewStatus @default(PENDING)
  areaId     String?
  area       Area?        @relation(fields: [areaId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([status, updatedAt])
}

model NowUpdate {
  id           String       @id @default(cuid())
  title        String
  body         String?
  category     String       @default("عام")
  status       ReviewStatus @default(PENDING)
  areaId       String?
  startsAt     DateTime     @default(now())
  endsAt       DateTime?
  area         Area?        @relation(fields: [areaId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  helpfulVotes NowHelpful[]

  @@index([status, startsAt, endsAt])
}

model NowHelpful {
  userId      String
  nowUpdateId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nowUpdate   NowUpdate @relation(fields: [nowUpdateId], references: [id], onDelete: Cascade)

  @@id([userId, nowUpdateId])
  @@index([nowUpdateId])
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

// --- Qena Data Collection v1 ---
// These models mirror prisma/migrations/20260721050000_data_collection_v1/migration.sql,
// which the data-collection module (src/data-collection/*) manages entirely through
// $queryRawUnsafe / $executeRawUnsafe rather than the generated Prisma Client API.
// They are declared here only so `prisma migrate dev` recognizes the tables as intentional
// and does not propose dropping them on the next schema diff. `providerId` below is a plain
// scalar (DB-level FK only, enforced by the migration SQL) rather than a Prisma relation, so
// the existing Provider model does not need a matching back-reference field.

enum CollectionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum CollectedRecordStatus {
  NEW
  NEEDS_REVIEW
  APPROVED
  REJECTED
  MERGED
}

enum SocialEnrichmentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model DataSource {
  id        String   @id
  name      String   @unique
  kind      String
  baseUrl   String?
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs      CollectionJob[]
  businesses CollectedBusiness[]
}

model CollectionJob {
  id             String              @id
  sourceId       String?
  category       String?
  area           String?
  query          String?
  status         CollectionJobStatus @default(PENDING)
  startedAt      DateTime?
  finishedAt     DateTime?
  foundCount     Int                 @default(0)
  savedCount     Int                 @default(0)
  duplicateCount Int                 @default(0)
  failedCount    Int                 @default(0)
  error          String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  source     DataSource?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  businesses CollectedBusiness[]

  @@index([status, createdAt])
}

model CollectedBusiness {
  id              String                 @id
  jobId           String?
  sourceId        String?
  externalId      String?
  name            String
  normalizedName  String
  category        String?
  subcategory     String?
  city            String                 @default("قنا")
  area            String?
  village         String?
  address         String?
  latitude        Float?
  longitude       Float?
  phone           String?
  normalizedPhone String?
  whatsapp        String?
  email           String?
  website         String?
  facebook        String?
  instagram       String?
  tiktok          String?
  googleMapsUrl   String?
  rating          Float?
  reviewCount     Int?
  openingHours    Json?
  rawData         Json?
  fingerprint     String                 @unique
  qualityScore    Int                    @default(0)
  status          CollectedRecordStatus  @default(NEW)
  reviewNote      String?
  reviewedAt      DateTime?
  reviewedBy      String?
  providerId      String?
  googlePlaceId          String?                @unique
  osmId                  String?                @unique
  socialEnrichment       Json?
  socialCandidates       Json?
  socialEnrichmentStatus SocialEnrichmentStatus @default(PENDING)
  socialEnrichmentError  String?
  socialEnrichedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  job    CollectionJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  source DataSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  duplicatesAsLeft  DuplicateCandidate[] @relation("duplicateLeft")
  duplicatesAsRight DuplicateCandidate[] @relation("duplicateRight")

  @@index([status, qualityScore])
  @@index([normalizedPhone])
  @@index([sourceId])
  @@index([socialEnrichmentStatus])
}

model DuplicateCandidate {
  id         String    @id
  leftId     String
  rightId    String
  score      Float
  reason     String
  resolved   Boolean   @default(false)
  resolution String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  left  CollectedBusiness @relation("duplicateLeft", fields: [leftId], references: [id], onDelete: Cascade)
  right CollectedBusiness @relation("duplicateRight", fields: [rightId], references: [id], onDelete: Cascade)

  @@index([resolved, score])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}
