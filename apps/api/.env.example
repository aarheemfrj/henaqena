# PostgreSQL محلي (Postgres.app): بدّل YOUR_MAC_USER باسم مستخدم macOS.
DATABASE_URL="postgresql://YOUR_MAC_USER@127.0.0.1:5432/henaqena?schema=public"
PORT=4000
API_HOST="127.0.0.1"
ADMIN_API_KEY="your-secure-admin-key-here-change-in-production"
# اختياري: مسار دائم للصور على الـ VPS ورابط API المتاح للجمهور.
UPLOADS_DIR="./uploads"
PUBLIC_API_BASE_URL="https://henaqena.maalsoft.com"
CORS_ORIGINS="https://henaqena.maalsoft.com"
# قبل التوسع: استبدل التخزين المحلي بـ S3/R2 عبر طبقة التخزين القادمة.
STORAGE_DRIVER="local"
# روابط Webhook لمزود إرسال رموز التأكيد. يستقبل كل رابط JSON يحتوي
# channel,target,code,purpose,app. اتركها فارغة محلياً لطباعة الرمز في سجل API.
WHATSAPP_OTP_WEBHOOK_URL=""
SMS_OTP_WEBHOOK_URL=""
EMAIL_OTP_WEBHOOK_URL=""
OTP_WEBHOOK_TOKEN=""
ENABLE_BACKGROUND_JOBS="true"
GOOGLE_CLIENT_IDS=""
APPLE_CLIENT_IDS=""
# Google Places API (New) — https://developers.google.com/maps/documentation/places/web-service/text-search
# مصدر google-maps في تجميع البيانات لا يُفعَّل إلا عند وجود مفتاح فعلي وتفعيل صريح.
GOOGLE_MAPS_API_KEY=""
GOOGLE_MAPS_PROVIDER_ENABLED="false"
# مزود بحث رسمي لإثراء روابط السوشيال (Google Programmable Search Engine / Custom Search JSON API).
# https://developers.google.com/custom-search/v1/overview
SEARCH_PROVIDER="google_custom_search"
SEARCH_API_KEY=""
SEARCH_ENGINE_ID=""
SOCIAL_ENRICHMENT_ENABLED="false"
